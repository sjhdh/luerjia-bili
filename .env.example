# Platform pages are rendered inside the application's interactive subwindow.
DEPLOYMENT_MODE=local
HOST=127.0.0.1
PORT=8000
PUBLIC_BASE_URL=
PDF_BASE_URL=
TRUSTED_HOSTS=127.0.0.1,localhost,testserver

# Required only when DEPLOYMENT_MODE=server.
ADMIN_USERNAME=operator
ADMIN_PASSWORD=
# Optional; defaults to a key derived from ADMIN_PASSWORD.
SESSION_SECRET=
SESSION_TTL_HOURS=12

# Set to true only for fast development or low-resource machines.
LIGHTWEIGHT_ANALYSIS=false
BROWSER_HEADLESS=true

# Optional OpenAI-compatible enhancement mode.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_BATCH_SIZE=120
LLM_CONCURRENCY=2
LLM_TIMEOUT_SECONDS=150
LLM_MAX_RETRIES=3
LLM_MAX_OUTPUT_TOKENS=8192
LLM_CONFIDENCE_THRESHOLD=0.62
LLM_LIGHTWEIGHT_MIN_ITEMS=800
LLM_LIGHTWEIGHT_MAX_RATIO=0.20
LLM_LIGHTWEIGHT_CONFIDENCE_THRESHOLD=0.70

# Optional authenticated proxy pool. Never commit real values.
ZDOPEN_APP_ID=
ZDOPEN_AKEY=

RAW_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=180
