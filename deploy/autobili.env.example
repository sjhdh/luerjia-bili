DEPLOYMENT_MODE=server
HOST=127.0.0.1
PORT=8000
PUBLIC_BASE_URL=https://autobili.luerjia.art
PDF_BASE_URL=http://127.0.0.1:8000
TRUSTED_HOSTS=autobili.luerjia.art,127.0.0.1,localhost

# Required in server mode. Use a unique randomly generated value.
ADMIN_USERNAME=operator
ADMIN_PASSWORD=

DATA_DIR=/var/lib/autobili/data
HF_HOME=/var/lib/autobili/model-cache
HF_ENDPOINT=https://hf-mirror.com
PLAYWRIGHT_BROWSERS_PATH=/var/lib/autobili/playwright
BROWSER_HEADLESS=true
BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
LIGHTWEIGHT_ANALYSIS=false
MODEL_BATCH_SIZE=4

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

RAW_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=180
